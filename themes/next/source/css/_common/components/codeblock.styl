// 代码块基础样式
code
  padding: 1px 5px
  font-family: Inconsolata, Monaco, Consolas, 'Courier New', Courier, monospace
  color: #e96900
  background-color: #f8f8f8
  border-radius: 2px

pre code
  padding: 0
  color: #e8eaf6
  background-color: #272822

pre[class*="language-"]
  padding: 1.2em
  margin: .5em 0

code[class*="language-"],
pre[class*="language-"]
  color: #e8eaf6
  white-space: pre-wrap !important

.line-numbers-rows
  border-right-width: 0px !important

.line-numbers
  padding: 1.5rem 1.5rem 1.5rem 3.2rem !important
  margin: 1rem 0 !important
  background: #272822
  overflow: auto
  border-radius: 0.35rem
  tab-size: 4

pre
  padding: 1.5rem !important
  margin: 1rem 0 !important
  background: #272822
  overflow: auto
  border-radius: 0.35rem
  tab-size: 4
  position: relative

  &::before
    content: ""
    height: 16px
    margin-bottom: 0
    display: block

  &::after
    content: " "
    position: absolute
    border-radius: 50%
    background: #ff5f56
    width: 12px
    height: 12px
    top: 0
    left: 12px
    margin-top: 12px
    -webkit-box-shadow: 20px 0 #ffbd2e, 40px 0 #27c93f
    box-shadow: 20px 0 #ffbd2e, 40px 0 #27c93f
.highlight-container {
  position: relative;
  margin: 1em 0;
  border-radius: 8px;
  overflow: hidden;
  background: #272822;

  // 适配Next原生复制按钮
  .code-copy-btn {
    right: 40px !important;
    top: 6px !important;
    filter: invert(50%);
    opacity: 0.6;
    transition: all 0.2s;
    
    &:hover {
      opacity: 1;
      transform: scale(1.1);
    }
    
    &[aria-label="Copied"] {
      background: #27c93f !important;
    }
  }
.code_copy
  display: none;
  position: absolute
  top: 0.7rem
  right: 35px
  z-index: 1
  filter: invert(50%)
  cursor: pointer
  opacity: 0.6
  transition: all 0.2s
  &:hover
    opacity: 1

.code_lang
  position: absolute
  top: 1.2rem
  right: 60px
  line-height: 0
  font-weight: bold
  font-family: -apple-system, sans-serif
  z-index: 1
  filter: invert(50%)
  cursor: pointer
  font-size: 12px

.code-expand
  position: absolute
  top: 4px
  right: 0px
  filter: invert(50%)
  padding: 7px 10px
  z-index: 1
  cursor: pointer
  transition: all .3s
  transform: rotate(0deg)
  opacity: 0.6
  &:hover
    opacity: 1

.code-closed
  .code-expand
    transform: rotate(-180deg) !important
    transition: all .3s
  pre::before
    height: 0px
  &:not(.has-next-copy-btn) {
    .code_copy {
      display: block;
      position: absolute;
      top: 0.7rem;
      right: 35px;
      z-index: 1;
      filter: invert(50%);
      cursor: pointer;
      opacity: 0.6;
      transition: all 0.2s;
      
      &:hover {
        opacity: 1;
      }
    }
  }